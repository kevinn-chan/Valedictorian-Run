# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-only; never expose to the client

# Auth allowlist (comma-separated; 2-user design)
ALLOWED_EMAILS=chankangle.kevin@gmail.com,tina@valedictorian.run

# Click-to-sign-in profiles shown on the login screen ("Name:email,Name:email")
PROFILES=Kevin:chankangle.kevin@gmail.com,Tina:tina@valedictorian.run

# LLM — Gemini free tier is primary; OpenAI Tier 3 is break-glass only
LLM_PROVIDER=google                    # google | openai (flip = full failover)
GOOGLE_GENERATIVE_AI_API_KEY=          # aistudio.google.com → Get API key
OPENAI_API_KEY=                        # break-glass account only

# Optional: require this bearer token on /api/keepalive (Vercel sends it automatically)
CRON_SECRET=
